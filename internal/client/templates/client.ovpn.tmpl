# Client: {{.Name}}  Generated: {{.Timestamp}}
client
dev tun
proto {{.Proto}}
remote {{.PublicIP}} {{.Port}}
resolv-retry infinite
nobind
persist-key
persist-tun
remote-cert-tls server

# Security
cipher {{.Cipher}}
{{if .DataCiphers}}data-ciphers {{.DataCiphers}}
{{end}}{{if .Auth}}auth {{.Auth}}
{{end}}allow-compression no
auth-nocache

{{if .RouteNoPull}}# Routes managed locally
route-nopull
route {{.Network}} {{.Netmask}}
{{end}}
verb {{.Verb}}

{{if .RDPEnabled}}# RDP/performance optimizations
# NOTE: fast-io disables DCO — omit if DCO is needed
sndbuf {{.SndBuf}}
rcvbuf {{.RcvBuf}}
tun-mtu {{.TunMTU}}
mssfix {{.MSSFix}}
{{if .FastIO}}fast-io
{{end}}{{end}}
