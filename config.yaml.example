# OpenVPN Manager configuration
# Place this file next to openvpn-manager.exe

openvpn_root: "C:\\Program Files\\OpenVPN"
openvpn_version: 27  # major version: 26 = OpenVPN 2.6.x, 27 = OpenVPN 2.7.x
                     # affects: windows-driver (removed in 2.7), persist-key (ignored in 2.7)

server:
  public_ip: ""            # leave empty for auto-detect via api.ipify.org
  port: 1194
  proto: udp               # udp or tcp
  windows_driver: wintun   # wintun (DCO, recommended) or tap-windows6 (legacy)
  network: "192.168.170.0"
  netmask: "255.255.255.0"
  topology: subnet
  cipher: AES-128-GCM
  data_ciphers: "AES-128-GCM:CHACHA20-POLY1305"
  auth: none       # none = let AEAD cipher handle auth (required for DCO)
                   # SHA256 = explicit HMAC (disables DCO, use only with CBC ciphers)
  keepalive: "10 60"
  tls_crypt: true          # false = use tls-auth instead
  verb: 2
  allow_compression: false # false = allow-compression no (required for DCO)

  # Routes pushed to all clients
  push_routes:
    - "route 192.168.170.0 255.255.255.0"
  # Any additional push directives
  extra_push_routes: []    # e.g. ["redirect-gateway def1"]

  # RDP/performance optimizations
  # Disable to use OpenVPN defaults
  rdp:
    enabled: true
    fast_io: false     # true = enables fast-io BUT disables DCO — choose one
    snd_buf: 2097152        # 2MB socket send buffer
    rcv_buf: 2097152        # 2MB socket recv buffer
    tun_mtu: 1400           # tun MTU (helps with fragmentation)
    mssfix: 1360            # TCP MSS clamp

client:
  inline_keys: true         # embed certs into .ovpn (recommended)
  route_nopull: false       # false = server pushes routes; true = local route only
  verb: 1

backup:
  enabled: true
